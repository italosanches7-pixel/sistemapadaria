DATABASE_URL="postgresql://usuario:senha@host:5432/nomedobanco"
JWT_SECRET="uma-string-secreta-bem-longa-e-aleatoria"

# Opcionais — recuperação/garantia do administrador.
# Se definidos, a cada publicação o sistema garante um admin com este login e senha
# (cria se não existir; redefine a senha se já existir). Deixe em branco para criar
# o admin pela tela de "Primeiro acesso" no navegador.
# ADMIN_LOGIN="admin"
# ADMIN_SENHA="defina-uma-senha-forte"
